# DEP-PM Platform — Backend environment (copy to .env, do NOT commit real values)

# Database connection string. Dev = SQLite file; staging/prod = PostgreSQL (ADR-01).
DATABASE_URL=sqlite:///./dep_pm.db

# Anthropic API key for the PM Agent (persona: PM). Required for /breakdown; leave blank
# to disable live agent calls (endpoints still work for manual task creation).
ANTHROPIC_API_KEY=

# Model id used by the Solo-Mode Claude agent. Configurable so we can bump versions
# without code changes (Open Question §9.5). Default = latest Claude Sonnet.
CLAUDE_MODEL=claude-sonnet-5

# Safety cap on tokens per single agent task (Risk Register #3).
MAX_TOKENS_PER_TASK=16000

# --- Team Mode (Sprint 4) ----------------------------------------------------
# 'solo' = Claude ทุกบทบาท | 'team' = dev->OpenAI, senior_architect->Gemini (Blueprint §9)
AGENT_MODE=solo
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-pro

# --- Deploy pipeline (Sprint 4) ----------------------------------------------
# GitHub fine-grained PAT ที่มีสิทธิ์ contents:write บน repo เป้าหมาย + "owner/repo"
# ว่างทั้งคู่ = stub mode (บันทึก deployment record แต่ไม่ยิง GitHub จริง)
GITHUB_TOKEN=
GITHUB_REPO=
# true = task ที่ orchestrator ทำเสร็จ (done) จะสร้าง staging deployment อัตโนมัติ
AUTO_DEPLOY_ENABLED=false

# CORS origin for the Next.js frontend (Sprint 3).
FRONTEND_ORIGIN=http://localhost:3000
